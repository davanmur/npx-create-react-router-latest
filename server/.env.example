# Copy to .env — this file is never committed to git
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the proxy listens on (default: 3001)
PORT=3001

# URL of your frontend — used for CORS.
# Development default is http://localhost:5173 (Vite).
# Change this to your deployed frontend URL in production.
ALLOWED_ORIGIN=http://localhost:5173
